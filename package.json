{
  "name": "opentype",
  "version": "0.1.0",
  "description": "AI-Powered Voice-to-Text for macOS. Type with your voice anywhere with 4 input modes, multi-provider AI processing, and privacy-first design.",
  "main": "dist/main/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -r \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:preload\"",
    "dev:main": "tsc -p src/main/tsconfig.json --watch",
    "dev:preload": "tsc -p src/preload/tsconfig.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p src/main/tsconfig.json",
    "build:preload": "tsc -p src/preload/tsconfig.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "kill": "osascript -e 'tell application \"OpenType\" to quit' 2>/dev/null || pkill -15 -f 'Electron.*opentype' 2>/dev/null || pkill -9 -f 'Electron.*opentype' 2>/dev/null; sleep 2; echo 'OpenType killed'",
    "restart": "npm run kill && npm run build && npm start",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "typecheck": "tsc --noEmit -p src/main/tsconfig.json && tsc --noEmit -p src/renderer/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "echo 'E2E tests not implemented yet' && exit 0",
    "ci": "npm run typecheck && npm run build && npm run test"
  },
  "keywords": [
    "dictation",
    "speech-to-text",
    "voice-to-text",
    "electron",
    "ai",
    "productivity",
    "macos",
    "whisper",
    "transcription",
    "voice-recognition"
  ],
  "author": {
    "name": "OpenType Contributors",
    "url": "https://github.com/G3niusYukki/OpenType/graphs/contributors"
  },
  "license": "MIT",
  "homepage": "https://github.com/G3niusYukki/OpenType#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/G3niusYukki/OpenType.git"
  },
  "bugs": {
    "url": "https://github.com/G3niusYukki/OpenType/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "darwin"
  ],
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.1.2",
    "electron": "^36.9.5",
    "electron-builder": "^26.4.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "form-data": "^4.0.0",
    "lucide-react": "^0.479.0",
    "node-fetch": "^3.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uiohook-napi": "^1.5.4",
    "zustand": "^5.0.3"
  },
  "build": {
    "appId": "com.opentype.app",
    "productName": "OpenType",
    "copyright": "Copyright © 2024 OpenType Contributors",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist"
    }
  }
}
