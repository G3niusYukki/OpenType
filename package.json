{
  "name": "opentype",
  "version": "0.1.0",
  "description": "A macOS-first dictation assistant with BYOK AI providers",
  "main": "dist/main/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -r \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:preload\"",
    "dev:main": "tsc -p src/main/tsconfig.json --watch",
    "dev:preload": "tsc -p src/preload/tsconfig.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p src/main/tsconfig.json",
    "build:preload": "tsc -p src/preload/tsconfig.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "kill": "pkill -9 -f 'Electron.*opentype' 2>/dev/null; pkill -9 -f 'electron.*OpenType' 2>/dev/null; sleep 1; echo 'OpenType killed'",
    "restart": "npm run kill && npm run build && npm start",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "typecheck": "tsc --noEmit -p src/main/tsconfig.json && tsc --noEmit -p src/renderer/tsconfig.json"
  },
  "keywords": ["dictation", "speech-to-text", "electron", "ai", "productivity"],
  "author": "OpenType",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^36.9.5",
    "electron-builder": "^26.4.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.1"
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "form-data": "^4.0.0",
    "lucide-react": "^0.479.0",
    "node-fetch": "^3.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.3"
  },
  "build": {
    "appId": "com.opentype.app",
    "productName": "OpenType",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "hardenedRuntime": true,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist"
    }
  }
}
